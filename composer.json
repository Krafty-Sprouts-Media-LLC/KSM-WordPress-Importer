{
	"name"              : "krafty-sprouts/better-wordpress-importer",
	"description"       : "Resumable, batch-based WordPress WXR importer",
	"license"           : "GPL-2.0-or-later",
	"authors"           : [
		{
			"name"     : "Krafty Sprouts Media, LLC",
			"homepage" : "https://github.com/Krafty-Sprouts-Media-LLC/KSM-WordPress-Importer"
		}
	],
	"type"              : "wordpress-plugin",
	"minimum-stability" : "dev",
	"prefer-stable"     : true,
	"support"           : {
		"source" : "https://github.com/Krafty-Sprouts-Media-LLC/KSM-WordPress-Importer",
		"issues" : "https://github.com/Krafty-Sprouts-Media-LLC/KSM-WordPress-Importer/issues"
	},
	"keywords" : [
		"wordpress",
		"plugin",
		"importer"
	],
	"require"           : {
		"php"                 : ">=7.4",
		"composer/installers" : "^1.0 || ^2.0"
	},
	"require-dev": {
		"wp-coding-standards/wpcs": "^3.0",
		"squizlabs/php_codesniffer": "^3.7",
		"phpcompatibility/phpcompatibility-wp": "^2.1"
	},
	"autoload"          : { },
	"autoload-dev"      : { },
	"extra"             : {
		"branch-alias"    : {
			"dev-dev" : "0.1.x-dev"
		},
		"installer-paths" : {
			"vendor/{$name}" : [
				"type:wordpress-plugin"
			]
		}
	},
	"scripts": {
		"post-install-cmd": "\"vendor/bin/phpcs\" --config-set installed_paths vendor/wp-coding-standards/wpcs",
		"post-update-cmd" : "\"vendor/bin/phpcs\" --config-set installed_paths vendor/wp-coding-standards/wpcs"
	}
}
